/* ==================== 全局样式变量 ==================== */
$primary-color = #409eff
$success-color = #67c23a
$warning-color = #e6a23c
$danger-color = #f56c6c
$info-color = #909399

$text-primary = #303133
$text-regular = #606266
$text-secondary = #909399
$text-placeholder = #c0c4cc

$border-base = #dcdfe6
$background-base = #f5f7fa

/* ==================== 全局混合 ==================== */
text-ellipsis()
  overflow: hidden
  text-overflow: ellipsis
  white-space: nowrap

flex-center()
  display: flex
  align-items: center
  justify-content: center
