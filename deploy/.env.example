# ============================================================
# 奇文网盘 — 环境变量配置模板
# 复制为 .env 后填写实际值：cp .env.example .env
# ============================================================

# ---- MySQL ----
MYSQL_ROOT_PASSWORD=your-mysql-root-password
DB_USERNAME=qiwenshare
DB_PASSWORD=your-db-password

# ---- Redis ----
REDIS_PASSWORD=your-redis-password

# ---- JWT（Base64 编码，解码后至少 32 字节）----
# 生成方式: echo -n "your-32-byte-secret-key-here" | base64
JWT_SECRET=dGhpcy1pcy1hLXZlcnktbG9uZy1zZWNyZXQta2V5LWZvci1qd3QtdG9rZW4tc2lnbmluZy0yNTYtYml0

# ---- OnlyOffice JWT（与 OnlyOffice 容器共享同一密钥）----
ONLYOFFICE_JWT_SECRET=your-onlyoffice-jwt-secret-min-32-chars

# ---- CORS（前端访问地址，多个用逗号分隔）----
# 示例: https://pan.example.com
CORS_ALLOWED_ORIGINS=http://localhost

# ---- Cookie 安全（HTTPS 部署时设为 true/None，HTTP 开发时设为 false/Lax）----
COOKIE_SECURE=false
COOKIE_SAME_SITE=Lax

# ---- Elasticsearch（可选，默认使用容器内地址）----
# ES_URIS=http://elasticsearch:9200
# ES_USERNAME=
# ES_PASSWORD=

# ---- 文件存储 ----
# 存储类型：local / minio / aliyun / qiniu / fastdfs
STORAGE_TYPE=local
# 宿主机文件存储目录（相对路径以 deploy/ 为基准，也可写绝对路径）
STORAGE_HOST_PATH=./data/files
